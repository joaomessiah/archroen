# Copy this file to ".env" and fill in only the key(s) the mode you run needs (see below),
# then load it before running, e.g.:
#   set -a && . ./.env && set +a && .venv/bin/python3 run_pipeline.py
#
# config.py reads each of these via os.environ; .env is gitignored (never committed).
# Where to get each key, and cost notes: docs/getting-started/api_keys.md
#
# Which key for which WORKFLOW_MODE (config.py):
#   rules-only   -> none (no AI; runs free / offline)
#   claude       -> ANTHROPIC_API_KEY
#   cloud-llama  -> LLM_API_KEY
#   local-llama  -> none (uses local Ollama)
# OCR of scanned PDFs (any mode, when OCR_ENABLED) -> GOOGLE_VISION_API_KEY

# Google Cloud Vision key — OCR of scanned / image-only PDFs (when OCR_ENABLED). Mode-independent.
# Example: GOOGLE_VISION_API_KEY="a-b-c-1"
GOOGLE_VISION_API_KEY=""

# Anthropic API key — Claude mode (WORKFLOW_MODE = "claude"); used for the whole workflow.
# Not needed if you use the Claude Code CLI path (HYBRID_USE_CLAUDE_CLI = True).
# Example: ANTHROPIC_API_KEY="a-b-c-2"
ANTHROPIC_API_KEY=""

# Cloud LLM key — Llama mode (WORKFLOW_MODE = "cloud-llama"). OpenAI-compatible host
# (Together by default; also OpenRouter / Fireworks / Groq / Cerebras).
# Example: LLM_API_KEY="a-b-c-3"
LLM_API_KEY=""
